# Copy this file to .env and fill in your values.
# .env is never committed to version control.

# Google Sheets published CSV URL
# To get this URL:
#   1. Open your Google Sheet
#   2. File → Share → Publish to web
#   3. Select the sheet, choose "Comma-separated values (.csv)", click Publish
#   4. Copy the URL and paste it below
SHEET_CSV_URL=https://docs.google.com/spreadsheets/d/e/2PACX-1vTPi0s2uJDoUE-5hvQa9AEBd8jZykMXsbPqzDbVakRQIBoWIVeArjpamnz1doc0as09t9cKR7ExSDRh/pub?output=csv
# SMTP settings for catering form email notifications
# Example below uses Gmail with an App Password (not your regular password).
# Generate one at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tester@gmail.com
SMTP_PASS=your_app_password_here

# The email address that receives new catering inquiries
NOTIFY_EMAIL=owner@eriestreetkitchen.com
